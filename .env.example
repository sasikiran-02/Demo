OKTA_ISSUER=https://your-okta-domain/oauth2/default
OKTA_CLIENT_ID=your-client-id
OKTA_CLIENT_SECRET=your-client-secret
OKTA_SCOPE=your-scope
OKTA_AUDIENCE=api://default
AGENTCORE_GATEWAY_URL=https://your-agentcore-gateway.example.com/invoke
AGENTCORE_API_KEY=
ENABLE_LOCAL_TOKEN_VALIDATION=false
REQUEST_TIMEOUT_MS=5000
ENVIRONMENT=dev
LOG_LEVEL=INFO
EXPOSE_RAW_ACCESS_TOKEN=false
